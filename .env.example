# Orchestrator
LUMPY_HOST=127.0.0.1
LUMPY_PORT=4317
LUMPY_DATA_DIR=./data
LUMPY_LOG_LEVEL=info

# Session engine
# Prefix applied to every tmux session Lumpy manages.
LUMPY_TMUX_PREFIX=lumpy
# Default command launched inside a new session's tmux window.
LUMPY_DEFAULT_COMMAND=claude
# Default root directory under which session workspaces are resolved.
LUMPY_WORKSPACE_ROOT=~/

# Web (Next.js)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:4317
