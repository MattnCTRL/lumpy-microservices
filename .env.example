# Orchestrator
LUMPY_HOST=127.0.0.1
LUMPY_PORT=4317
LUMPY_DATA_DIR=./data
LUMPY_LOG_LEVEL=info

# Session engine
# Prefix applied to every tmux session Lumpy manages.
LUMPY_TMUX_PREFIX=lumpy
# Default command launched inside a new session's tmux window.
LUMPY_DEFAULT_COMMAND=claude
# Default root directory under which session workspaces are resolved.
LUMPY_WORKSPACE_ROOT=~/
# Run sessions as this non-root OS user (recommended in production). Empty = self.
LUMPY_SESSION_USER=

# Remediation: off | investigate | auto. Severities that auto-run (others need approval).
LUMPY_REMEDIATION_MODE=off
LUMPY_REMEDIATION_AUTO_SEVERITIES=warning

# Authentication (Sign in with GitHub) — leave blank to disable. See docs/auth.md.
LUMPY_GITHUB_CLIENT_ID=
LUMPY_GITHUB_CLIENT_SECRET=
LUMPY_AUTH_SECRET=
LUMPY_WEB_URL=

# Notifications (ntfy) — leave the topic empty to disable push notifications.
LUMPY_NTFY_URL=https://ntfy.sh
LUMPY_NTFY_TOPIC=
# Base URL the phone can reach (a Tailscale address) for notification deep links
# and approve/reject action buttons. Optional.
LUMPY_PUBLIC_URL=

# Web (Next.js)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://127.0.0.1:4317
