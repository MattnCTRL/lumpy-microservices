{
  "name": "lumpy-microservices",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted orchestrator for multiple Claude Code sessions and remote server fleet monitoring.",
  "license": "MIT",
  "author": "Matthew Whiteman",
  "homepage": "https://github.com/mattnctrl/lumpy-microservices",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n orchestrator,web -c blue,magenta \"npm:dev:orchestrator\" \"npm:dev:web\"",
    "dev:orchestrator": "npm run dev -w @lumpy/orchestrator",
    "dev:web": "npm run dev -w @lumpy/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
