{
  "name": "@lumpy/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --external:@lumpy/shared --outfile=dist/agent.mjs",
    "test": "LUMPY_LOG_LEVEL=silent node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lumpy/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
